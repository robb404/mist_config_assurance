# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Token encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Backend URL (used by Next.js to call Python)
BACKEND_URL=http://localhost:8001

# OpenAI OAuth (only needed if using OpenAI OAuth auth method)
# Register your app at: https://platform.openai.com/docs/guides/authentication
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=

# Public app URL — used as OAuth redirect_uri base (no trailing slash)
# Dev: http://localhost:3000  Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public app URL — used to build the Mist webhook URL shown in Settings
# Dev: http://localhost:3000  Prod: https://your-app.vercel.app
APP_URL=http://localhost:3000

# Resend email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Debug logs — set to true to expose the live log panel under Settings
ENABLE_DEBUG_LOGS=false
